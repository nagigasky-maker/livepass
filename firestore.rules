// ─────────────────────────────────────────────
// EXPASS — Firestore Security Rules
//
// Deploy with:  firebase deploy --only firestore:rules
//
// Design notes:
// - Users can only read/write their own `users/{uid}` document.
// - Posts (articles / events / workshops / exhibitions) are publicly
//   readable (so followers can see them) but writeable only by the
//   account that created them (matched by `authorUid`).
// - Reservations are private to the user who made them.
// - Everything else is denied by default.
// ─────────────────────────────────────────────
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reusable helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function ownsResource() {
      return isSignedIn() && resource.data.authorUid == request.auth.uid;
    }
    function writingAsSelf() {
      return isSignedIn() && request.resource.data.authorUid == request.auth.uid;
    }

    // ── Users: each user owns their own profile ──
    //
    // CREATE: a new account may only be written with plan == 'free'.
    // UPDATE: the plan / planExpiresAt / planSource fields are read-only
    //         from the client — they can only be changed server-side
    //         (Stripe webhook or invite-redeem admin endpoint). Clients
    //         cache plan locally from the invite response; UI gates are
    //         cosmetic until real server writes land.
    match /users/{uid} {
      allow read: if isSignedIn();                 // signed-in users can look up profiles
      allow create: if isOwner(uid)
                    && request.resource.data.keys().hasOnly([
                         'name','email','plan','avatar','role','bio',
                         'coverUrl','profession','tier',
                         'agreedTermsAt','createdAt','updatedAt'
                       ])
                    && (!('plan' in request.resource.data) || request.resource.data.plan == 'free');
      allow update: if isOwner(uid)
                    && request.resource.data.keys().hasOnly([
                         'name','email','plan','avatar','role','bio',
                         'coverUrl','profession','tier',
                         'planExpiresAt','planSource',
                         'agreedTermsAt','createdAt','updatedAt'
                       ])
                    && request.resource.data.get('plan', 'free') == resource.data.get('plan', 'free')
                    && request.resource.data.get('planExpiresAt', null) == resource.data.get('planExpiresAt', null)
                    && request.resource.data.get('planSource', null) == resource.data.get('planSource', null);
      allow delete: if isOwner(uid);
    }

    // ── Invite codes (admin-managed) ──
    // Clients never read or write these directly — the /api/redeem-invite
    // server endpoint validates codes and issues the plan. Public reads
    // would leak the 30 seed codes.
    match /invites/{code} {
      allow read, write: if false;
    }

    // ── Usernames / handle registry ──
    // One doc per lowercased handle: { uid, name, claimedAt }.
    // Read: any signed-in user, so onboarding can probe availability
    //        before creating an auth account.
    // Create: must be signed in AND the claim must point to the
    //         current user's own uid.
    // Update / delete: only the owner of the claim.
    match /usernames/{nameLower} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasOnly(['uid','name','claimedAt']);
      allow update, delete: if isSignedIn()
                             && resource.data.uid == request.auth.uid;
    }

    // ── Posts (articles / events / workshops / exhibitions) ──
    // Stored flat under /posts/{id} with a `type` field.
    match /posts/{postId} {
      allow read: if true;                                            // public feed
      allow create: if writingAsSelf()
                    && request.resource.data.type in
                       ['article','event','workshop','exhibition'];
      allow update: if ownsResource() && writingAsSelf();
      allow delete: if ownsResource();
    }

    // ── Private reservations: only visible to the reserver ──
    match /reservations/{resId} {
      allow read, update, delete: if isSignedIn()
                                  && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
    }

    // ── Private subscriptions / payments log ──
    // Only backend writes (via Stripe webhook). Clients may read their own.
    match /subscriptions/{subId} {
      allow read: if isSignedIn()
                  && resource.data.userId == request.auth.uid;
      allow write: if false;                                          // server-only
    }

    // Deny anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
