{
  "rewrites": [
    { "source": "/p/amd",    "destination": "/livepass_flashback.html" },
    { "source": "/",         "destination": "/livepass_home.html" },
    { "source": "/home",     "destination": "/livepass_home.html" },
    { "source": "/search",   "destination": "/livepass_search.html" },
    { "source": "/calendar", "destination": "/livepass_calendar.html" },
    { "source": "/profile",  "destination": "/livepass_profile.html" },
    { "source": "/settings", "destination": "/livepass_settings.html" },
    { "source": "/onboarding","destination": "/livepass_onboarding.html" },
    { "source": "/signup",    "destination": "/livepass_onboarding.html" },
    { "source": "/start",     "destination": "/livepass_home.html" },
    { "source": "/app",       "destination": "/livepass_home.html" },
    { "source": "/feed",      "destination": "/livepass_home.html" },
    { "source": "/me",        "destination": "/livepass_profile.html" },
    { "source": "/compose/article",  "destination": "/livepass_compose_article.html" },
    { "source": "/compose/event",    "destination": "/livepass_compose_event.html" },
    { "source": "/compose/workshop",   "destination": "/livepass_compose_workshop.html" },
    { "source": "/compose/exhibition", "destination": "/livepass_compose_exhibition.html" },
    { "source": "/checkout/success",   "destination": "/livepass_checkout_success.html" },
    { "source": "/checkout/cancel",    "destination": "/livepass_checkout_cancel.html" },
    { "source": "/messages",           "destination": "/livepass_messages.html" },
    { "source": "/followers",          "destination": "/livepass_followers.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/(home|search|calendar|profile|settings|messages|followers|onboarding|signup|start|app|feed|me|compose/(article|event|workshop|exhibition)|checkout/(success|cancel)|p/amd)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
